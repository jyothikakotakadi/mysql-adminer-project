version: '3'

services:
  mysql:
    image: mysql:8.0
    container_name: mysql-container
    restart: always
    environment:
      MYSQL_ROOT_PASSWORD: root123
      MYSQL_DATABASE: employee_db
    ports:
      - "3306:3306"

  adminer:
    image: adminer
    container_name: adminer-container
    restart: always
    ports:
      - "8081:8080"

